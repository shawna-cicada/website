# External assessment provider URLs (Phase 5).
# Each assessment renders as "available soon" until its URL is set —
# provider links are never hardcoded in the repo. UTM parameters are
# appended automatically (utm_source, utm_medium, utm_campaign).
#
# Example (placeholder domain only — replace with the real provider link):
# ASSESSMENT_URL_GROWTH_STAGE=https://assessments.example.com/growth-stage
ASSESSMENT_URL_GROWTH_STAGE=
ASSESSMENT_URL_FOUNDER_GROWTH=
ASSESSMENT_URL_LEADERSHIP_ALIGNMENT=
ASSESSMENT_URL_AI_READINESS=
ASSESSMENT_URL_ORG_EFFECTIVENESS=

# Booking (Phase 5). BOOKING_PROVIDER is "calendly" or "calcom" (both
# implemented — see lib/booking/README.md). Event URLs must be PUBLIC
# scheduling links — never private calendar data. Each event type
# renders an accessible fallback until its URL is set.
# Cal.com links look like https://cal.com/<username>/<event-slug>.
BOOKING_PROVIDER=calcom
CALCOM_EVENT_URL_DISCOVERY_CALL=
CALCOM_EVENT_URL_ASSESSMENT_DEBRIEF=
CALCOM_EVENT_URL_EXISTING_CLIENT=
CALCOM_EVENT_URL_COACHING_SESSION=
# Calendly equivalents (used when BOOKING_PROVIDER=calendly):
CALENDLY_EVENT_URL_DISCOVERY_CALL=
CALENDLY_EVENT_URL_ASSESSMENT_DEBRIEF=
CALENDLY_EVENT_URL_EXISTING_CLIENT=
CALENDLY_EVENT_URL_COACHING_SESSION=
# Shown as a contact fallback when scheduling is unavailable.
BOOKING_CONTACT_EMAIL=

# Sanity (admin Studio at /admin + published /insights content).
# The live project's PUBLIC coordinates are committed as defaults in
# lib/sanity/config.ts (D-020) — nothing to set for normal use. These
# overrides exist for forks or a future staging dataset only.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Social syndication (LinkedIn workflow). Manual is the default and the
# only supported mode today: the CMS generates post copy, a human posts
# it. Automation requires BOTH flags below to change AND an approved,
# registered provider implementation (see docs/LINKEDIN_WORKFLOW.md) —
# nothing auto-posts otherwise.
SOCIAL_PUBLISH_MODE=manual
SOCIAL_PUBLISH_PROVIDER=manual-linkedin
